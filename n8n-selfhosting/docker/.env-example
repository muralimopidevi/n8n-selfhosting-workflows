# ═══════════════════════════════════════════════════════════════════════
# n8n Production — Environment Variables
# Copy to .env and fill in all values before deploying.
# NEVER commit a populated .env to version control.
# ═══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# DEPLOYMENT PATHS
# Absolute path where n8n volumes will be stored
# Examples: ./data (relative), /opt/n8n/volumes (absolute)
# ─────────────────────────────────────────────────────────────────
N8N_VOLUMES_ROOT=/opt/n8n/volumes

# ─────────────────────────────────────────────────────────────────
# n8n APPLICATION
# Replace with your actual domain name
# For local testing, use: localhost or 127.0.0.1
# ─────────────────────────────────────────────────────────────────
N8N_VERSION=1.123.28
N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.example.com/

# N8N_ENCRYPTION_KEY — MUST be hex, exactly 64 chars (32 bytes)
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_hex_32

# Disable n8n telemetry and background outbound checks for self-hosted installs
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false

# Worker concurrency (parallel jobs per worker)
N8N_WORKER_CONCURRENCY=10

# Task runners (executes Code node in a sandboxed process — recommended)
N8N_RUNNERS_ENABLED=true

# Enforce secure file permissions for n8n settings file
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# ─────────────────────────────────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────────────────────────────────
N8N_POSTGRES_DB=n8n
N8N_POSTGRES_USER=n8n
# Generate with: openssl rand -base64 48  (48 bytes → 64-char output)
# Larger is fine: -base64 64 (88 chars), -base64 128 (172 chars) all work
# NOTE: base64 output contains +/= chars — safe in .env, not on raw CLI
N8N_POSTGRES_PASSWORD=CHANGE_ME_run_openssl_rand_base64_48

# ─────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
N8N_REDIS_PASSWORD=CHANGE_ME_run_openssl_rand_base64_48

# ─────────────────────────────────────────────────────────────────
# LOGGING & OBSERVABILITY
# ─────────────────────────────────────────────────────────────────
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console
N8N_METRICS=false
N8N_GENERIC_TIMEZONE=UTC

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: BASIC AUTHENTICATION
# Uncomment to enable basic auth for n8n web interface
# Recommended if not using a reverse proxy with authentication
# ─────────────────────────────────────────────────────────────────
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_use_strong_password

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: EMAIL CONFIGURATION (for notifications)
# ─────────────────────────────────────────────────────────────────
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.example.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=your-email@example.com
# N8N_SMTP_PASS=your-smtp-password
# N8N_SMTP_SENDER=n8n@example.com
